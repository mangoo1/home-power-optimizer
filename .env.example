# ── Amber Electric ────────────────────────────────────────────────────────────
AMBER_BASE_URL=https://api.amber.com.au/v1
AMBER_API_TOKEN=your_amber_api_token_here
AMBER_SITE_ID=your_site_id_here

# ── ESS-Link Inverter ─────────────────────────────────────────────────────────
